<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Ritmo_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Ritmo_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Ritmo"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView x:Name="Nav"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Left"
                    SelectionChanged="Nav_SelectionChanged"
                    ItemInvoked="Nav_ItemInvoked"
                    Loaded="Nav_Loaded">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Hoy" Tag="home" IsSelected="True">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8D1;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Temporizador" Tag="timer">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE916;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Horario" Tag="schedule">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE787;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="WorkEnvNav" Content="Entornos de trabajo" Tag="workenv" SelectsOnInvoked="False">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE821;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Ayuda" Tag="help">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE897;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Ajustes" Tag="settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <SplitView x:Name="RightPanel" PanePlacement="Right" DisplayMode="Overlay"
                   OpenPaneLength="340" IsPaneOpen="False"
                   PaneBackground="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <SplitView.Pane>
                <Grid Padding="16" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="2">
                        <TextBlock Text="Entornos de trabajo" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Accesos rápidos por entorno." Opacity="0.7" FontSize="12" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="WorkEnvPanel" Spacing="8" />
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>
            <Frame x:Name="ContentFrame" />
        </SplitView>
    </NavigationView>
</Window>
