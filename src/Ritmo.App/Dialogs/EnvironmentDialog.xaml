<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Ritmo_App.Dialogs.EnvironmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Entorno de concentración"
    PrimaryButtonText="Guardar"
    SecondaryButtonText="Cancelar"
    DefaultButton="Primary">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
        <StackPanel Spacing="14" Width="360">
            <TextBox x:Name="NameBox" Header="Nombre" PlaceholderText="p. ej. Estudio profundo" />

            <ComboBox x:Name="PresetBox" Header="Ritmo Pomodoro" HorizontalAlignment="Stretch" />

            <StackPanel x:Name="FocusBehaviorSection" Spacing="6">
                <TextBlock Text="Al concentrarte" FontWeight="SemiBold" />
                <CheckBox x:Name="DndCheck" Content="Activar No molestar" />
                <CheckBox x:Name="BadgesCheck" Content="Ocultar avisos de la barra de tareas" />
                <CheckBox x:Name="OpenLinksCheck" Content="Abrir los enlaces en una ventana nueva del navegador" />
                <CheckBox x:Name="NewDesktopCheck" Content="Crear un escritorio virtual nuevo (Windows)" />
            </StackPanel>

            <StackPanel x:Name="MusicSection" Spacing="6">
                <TextBlock Text="Música" FontWeight="SemiBold" />
                <ComboBox x:Name="MusicAppBox" Header="App de música" HorizontalAlignment="Stretch"
                          SelectionChanged="MusicAppBox_SelectionChanged" />
                <StackPanel x:Name="NavidromePanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock x:Name="NavidromeLabel" Text="Sin playlist elegida" Opacity="0.7" FontSize="12" />
                    <Button x:Name="ConfigureNavidromeBtn" Click="ConfigureNavidromeBtn_Click"
                            Content="Elegir playlist de Navidrome…" HorizontalAlignment="Left" />
                </StackPanel>
                <CheckBox x:Name="AutoPlayCheck" Content="Intentar reproducir automáticamente al concentrarte" />
            </StackPanel>

            <StackPanel x:Name="ConnectorsSection" Spacing="6">
                <TextBlock Text="Conectores (apps al concentrarte)" FontWeight="SemiBold" />
                <TextBlock Text="Qué hace Ritmo con cada app al concentrarte (abrir / cerrar / silenciar). Las apps «Abrir» se abren en TODAS las sesiones salvo que abajo, en «Por tipo de sesión», elijas un subconjunto."
                           Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="ConnectorsBtn" Content="Conectores…" Click="ConnectorsBtn_Click" />
                    <TextBlock x:Name="AppsSummary" VerticalAlignment="Center" Opacity="0.75" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel x:Name="OtherAppsPanel" Spacing="4" />
            </StackPanel>

            <StackPanel x:Name="BlockedWebsSection" Spacing="6">
                <TextBlock Text="Webs a bloquear" FontWeight="SemiBold" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="WebInputBox" Grid.Column="0" PlaceholderText="youtube.com"
                             AutomationProperties.Name="Web a bloquear" KeyDown="WebInputBox_KeyDown" />
                    <Button x:Name="AddWebBtn" Grid.Column="1" Click="AddWebBtn_Click" Content="Añadir"
                            AutomationProperties.Name="Agregar web a la lista" />
                </Grid>
                <StackPanel x:Name="WebsList" Spacing="2" />
            </StackPanel>

            <StackPanel x:Name="LinksSection" Spacing="6">
                <TextBlock Text="Enlaces y herramientas del entorno (por defecto)" FontWeight="SemiBold" />
                <TextBlock Text="Por defecto se abren todos al concentrarte. Abajo, en «Por tipo de sesión», puedes abrir solo algunos según la sesión."
                           Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                <StackPanel x:Name="LinksList" Spacing="4" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LinkTitleBox" Grid.Column="0" PlaceholderText="Título" />
                    <TextBox x:Name="LinkUrlBox" Grid.Column="1" PlaceholderText="https://…" />
                    <Button x:Name="AddLinkBtn" Grid.Column="2" Click="AddLinkBtn_Click" Content="Añadir" />
                </Grid>
            </StackPanel>

            <!-- Comportamiento por tipo de sesión (#116) -->
            <StackPanel x:Name="SessionProfilesSection" Spacing="6">
                <TextBlock Text="Por tipo de sesión" FontWeight="SemiBold" />
                <TextBlock Text="Para cada tipo de sesión del horario (agrupado por título) puedes elegir qué subconjunto de las apps y enlaces de arriba se abre. Si no lo personalizas, se abre todo."
                           Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                <StackPanel x:Name="SessionProfilesPanel" Spacing="4" />
                <TextBlock x:Name="NoTitlesHint" Text="Aún no hay sesiones en el horario para configurar."
                           Opacity="0.6" FontSize="12" Visibility="Collapsed" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
