<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Ritmo_App.Dialogs.ConnectionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Añadir conexión"
    CloseButtonText="Cerrar"
    DefaultButton="Close">

    <!-- Catálogo de descubrimiento: aquí se DESCUBRE y se AÑADE una conexión.
         La gestión del día a día vive en Ajustes › Conexiones (no aquí). -->
    <ScrollViewer MaxHeight="520" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Width="440">
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="13"
                       Text="Conecta Ritmo con apps externas. Añade una aquí; luego la gestionas en Ajustes › Conexiones." />

            <!-- Notificaciones al móvil (ntfy) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="📱  Notificaciones al móvil (ntfy)" FontWeight="SemiBold" FontSize="15" />
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="Recibe los avisos del horario en el teléfono mediante la app gratuita ntfy. Sin cuenta: al conectar se genera un topic privado y luego lo gestionas en Ajustes." />
                    <Button x:Name="NtfyConnectBtn" Content="Conectar" Click="NtfyConnectBtn_Click"
                            Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                    <TextBlock x:Name="NtfyAlreadyText" Visibility="Collapsed" Opacity="0.75" FontSize="12"
                               Text="✓ Ya conectada. Gestiónala en Ajustes › Conexiones." />
                </StackPanel>
            </Border>

            <!-- Calendarios (OAuth) — futuro #112 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Opacity="0.65">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📅  Calendarios (Google · Outlook · Apple)" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                        <Border Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}" CornerRadius="4"
                                Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="Próximamente" FontSize="11" />
                        </Border>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12"
                               Text="Conexión OAuth para sincronizar calendarios. De momento puedes suscribir calendarios por enlace ICS (solo lectura) en Ajustes." />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
