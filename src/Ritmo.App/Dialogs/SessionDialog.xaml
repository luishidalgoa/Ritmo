<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Ritmo_App.Dialogs.SessionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Sesión"
    PrimaryButtonText="Guardar"
    SecondaryButtonText="Cancelar"
    DefaultButton="Primary">

    <StackPanel Spacing="12" Width="320">
        <!-- Editable: reutiliza títulos existentes del horario para no fragmentarlos (#116) -->
        <ComboBox x:Name="TitleBox" Header="Título" IsEditable="True" HorizontalAlignment="Stretch"
                  PlaceholderText="p. ej. Técnico (elige uno existente o escribe)" />

        <StackPanel Spacing="6">
            <TextBlock Text="Días" FontWeight="SemiBold" />
            <StackPanel x:Name="DayToggles" Orientation="Horizontal" Spacing="6">
                <ToggleButton x:Name="DayMon" Content="L" MinWidth="40" />
                <ToggleButton x:Name="DayTue" Content="M" MinWidth="40" />
                <ToggleButton x:Name="DayWed" Content="X" MinWidth="40" />
                <ToggleButton x:Name="DayThu" Content="J" MinWidth="40" />
                <ToggleButton x:Name="DayFri" Content="V" MinWidth="40" />
                <ToggleButton x:Name="DaySat" Content="S" MinWidth="40" />
                <ToggleButton x:Name="DaySun" Content="D" MinWidth="40" />
            </StackPanel>
            <TextBlock x:Name="DayHint" Text="Marca varios para crearlo en todos a la vez."
                       Opacity="0.6" FontSize="12" />
        </StackPanel>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TimePicker x:Name="StartPicker" Grid.Column="0" Header="Inicio" ClockIdentifier="24HourClock" MinuteIncrement="5" />
            <TimePicker x:Name="EndPicker" Grid.Column="1" Header="Fin" ClockIdentifier="24HourClock" MinuteIncrement="5" />
        </Grid>

        <ComboBox x:Name="KindBox" Header="Tipo" HorizontalAlignment="Stretch">
            <ComboBoxItem Content="Técnico" Tag="Tecnico" />
            <ComboBoxItem Content="Legislación" Tag="Legislacion" />
            <ComboBoxItem Content="Inglés" Tag="Ingles" />
            <ComboBoxItem Content="Tests" Tag="Tests" />
            <ComboBoxItem Content="Simulacro" Tag="Simulacro" />
            <ComboBoxItem Content="Descanso" Tag="Descanso" />
            <ComboBoxItem Content="Personal (comida, deporte…)" Tag="Personal" />
            <ComboBoxItem Content="Por definir" Tag="PorDefinir" />
            <ComboBoxItem Content="Otro" Tag="Otro" />
        </ComboBox>

        <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Avisos previos" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ContentControl x:Name="AlertHelp" VerticalAlignment="Center" />
            </StackPanel>

            <ComboBox x:Name="Alert1Box" Header="Aviso 1" HorizontalAlignment="Stretch"
                      SelectionChanged="Alert1Box_SelectionChanged">
                <ComboBoxItem Content="Ninguno" Tag="0" />
                <ComboBoxItem Content="5 minutos antes" Tag="5" />
                <ComboBoxItem Content="10 minutos antes" Tag="10" />
                <ComboBoxItem Content="15 minutos antes" Tag="15" />
                <ComboBoxItem Content="30 minutos antes" Tag="30" />
                <ComboBoxItem Content="1 hora antes" Tag="60" />
                <ComboBoxItem Content="2 horas antes" Tag="120" />
                <ComboBoxItem Content="Personalizado…" Tag="custom" />
            </ComboBox>
            <NumberBox x:Name="Alert1Custom" Visibility="Collapsed" Header="Minutos antes"
                       Minimum="1" Maximum="1440" SmallChange="5" SpinButtonPlacementMode="Inline" />

            <ComboBox x:Name="Alert2Box" Header="Aviso 2" HorizontalAlignment="Stretch"
                      SelectionChanged="Alert2Box_SelectionChanged">
                <ComboBoxItem Content="Ninguno" Tag="0" />
                <ComboBoxItem Content="5 minutos antes" Tag="5" />
                <ComboBoxItem Content="10 minutos antes" Tag="10" />
                <ComboBoxItem Content="15 minutos antes" Tag="15" />
                <ComboBoxItem Content="30 minutos antes" Tag="30" />
                <ComboBoxItem Content="1 hora antes" Tag="60" />
                <ComboBoxItem Content="2 horas antes" Tag="120" />
                <ComboBoxItem Content="Personalizado…" Tag="custom" />
            </ComboBox>
            <NumberBox x:Name="Alert2Custom" Visibility="Collapsed" Header="Minutos antes"
                       Minimum="1" Maximum="1440" SmallChange="5" SpinButtonPlacementMode="Inline" />
        </StackPanel>

        <ToggleSwitch x:Name="TentativeSwitch" Header="Provisional (no dispara concentración)" OffContent="No" OnContent="Sí" />
    </StackPanel>
</ContentDialog>
