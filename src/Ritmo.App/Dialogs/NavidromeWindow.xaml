<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Ritmo_App.Dialogs.NavidromeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Elegir playlist de Navidrome">

    <Grid Background="#1B1B2A" RequestedTheme="Dark" Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE93C;" FontSize="18" Foreground="#5B8DEF" />
                <TextBlock Text="Navidrome" FontSize="20" FontWeight="Bold" Foreground="White" />
            </StackPanel>
            <TextBlock x:Name="ServerSub" Text="Elige una playlist para este entorno." Foreground="#A9A9C2" FontSize="13" />
        </StackPanel>

        <Grid Grid.Row="1">
            <!-- Sin conexión -->
            <StackPanel x:Name="NotConnectedPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="No hay conexión a Navidrome." Foreground="White" HorizontalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Text="Conéctala en Ajustes → Navidrome y vuelve aquí." Foreground="#A9A9C2" HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="40" Height="40" Foreground="#5B8DEF" />
                <TextBlock Text="Cargando playlists…" Foreground="#A9A9C2" />
            </StackPanel>

            <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#FF8A8A" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380" />
                <Button Content="Reintentar" Click="RetryBtn_Click" HorizontalAlignment="Center" />
            </StackPanel>

            <Grid x:Name="ListPanel" RowSpacing="10" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox x:Name="SearchBox" Grid.Row="0" PlaceholderText="Buscar playlist…" TextChanged="SearchBox_TextChanged" />
                <GridView x:Name="PlaylistGrid" Grid.Row="1" SelectionMode="Single"
                          IsItemClickEnabled="True" ItemClick="PlaylistGrid_ItemClick"
                          SelectionChanged="PlaylistGrid_SelectionChanged">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="150" Margin="6" Padding="8" CornerRadius="8" Background="#252539">
                                <StackPanel Spacing="8">
                                    <Border CornerRadius="6" Background="#33334D" Width="134" Height="134">
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxWidth="134" />
                                    <TextBlock Text="{Binding Meta}" Foreground="#A9A9C2" FontSize="12"
                                               TextTrimming="CharacterEllipsis" MaxWidth="134" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="UseBtn" Click="UseBtn_Click" IsEnabled="False"
                    Background="#5B8DEF" Foreground="White" CornerRadius="6" Padding="18,8">
                <TextBlock Text="Usar esta playlist" FontWeight="SemiBold" />
            </Button>
            <Button Content="Cancelar" Click="CancelBtn_Click" CornerRadius="6" Padding="18,8" />
        </StackPanel>
    </Grid>
</Window>
