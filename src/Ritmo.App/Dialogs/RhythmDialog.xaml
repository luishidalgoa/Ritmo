<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Ritmo_App.Dialogs.RhythmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Nuevo ritmo Pomodoro"
    PrimaryButtonText="Guardar"
    SecondaryButtonText="Cancelar"
    DefaultButton="Primary">

    <StackPanel Spacing="14" Width="320">
        <TextBox x:Name="NameBox" Header="Nombre" PlaceholderText="p. ej. Sprint corto" />
        <Grid ColumnSpacing="16" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <NumberBox x:Name="FocusBox" Grid.Row="0" Grid.Column="0" Header="Concentración (min)"
                       Minimum="1" Maximum="180" SmallChange="5" SpinButtonPlacementMode="Inline" />
            <NumberBox x:Name="ShortBox" Grid.Row="0" Grid.Column="1" Header="Descanso corto (min)"
                       Minimum="0" Maximum="60" SmallChange="1" SpinButtonPlacementMode="Inline" />
            <NumberBox x:Name="LongBox" Grid.Row="1" Grid.Column="0" Header="Descanso largo (min)"
                       Minimum="0" Maximum="120" SmallChange="5" SpinButtonPlacementMode="Inline" />
            <NumberBox x:Name="CyclesBox" Grid.Row="1" Grid.Column="1" Header="Focos por descanso largo"
                       Minimum="1" Maximum="12" SmallChange="1" SpinButtonPlacementMode="Inline" />
        </Grid>
    </StackPanel>
</ContentDialog>
