<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Ritmo_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Ritmo_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="48" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center" MaxWidth="520">
            <FontIcon Glyph="&#xE916;" FontSize="56" HorizontalAlignment="Center"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="Ritmo" FontSize="40" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Pomodoro + horario semanal para opositar sin distracciones."
                       Opacity="0.7" TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <Border Margin="0,20,0,0" Padding="20,16" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Preset Pomodoro activo" FontWeight="SemiBold" />
                    <TextBlock x:Name="PomodoroInfo" Opacity="0.8" />
                    <TextBlock x:Name="EngineState" Opacity="0.8" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
