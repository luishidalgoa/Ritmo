<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ritmo_App.TimerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="48" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="560">
        <StackPanel x:Name="SubjectBadge" Spacing="2" HorizontalAlignment="Center" Visibility="Collapsed">
            <TextBlock x:Name="SubjectText" Text="" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="SubjectMeta" Text="" Opacity="0.6" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center" />
        </StackPanel>

        <ComboBox x:Name="EnvBox" Header="Entorno" HorizontalAlignment="Center" MinWidth="240"
                  SelectionChanged="EnvBox_SelectionChanged" />

        <Border x:Name="PhaseBadge" Padding="14,5" CornerRadius="14" HorizontalAlignment="Center"
                Background="{ThemeResource AccentFillColorDefaultBrush}">
            <TextBlock x:Name="PhaseText" Text="Listo para empezar" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
        </Border>

        <TextBlock x:Name="TimeText" Text="50:00" FontSize="92" FontWeight="SemiBold"
                   HorizontalAlignment="Center" FontFamily="Consolas" />

        <ProgressBar x:Name="Progress" Minimum="0" Maximum="1" Value="0" Width="420" Height="6" />
        <TextBlock x:Name="FocusCount" Text="Focos completados: 0" Opacity="0.7" HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="StartBtn" Click="StartBtn_Click" Style="{StaticResource AccentButtonStyle}">
                <TextBlock x:Name="StartBtnText" Text="Iniciar" />
            </Button>
            <Button x:Name="PauseBtn" Click="PauseBtn_Click" IsEnabled="False" Content="Pausar" />
            <Button x:Name="SkipBtn" Click="SkipBtn_Click" IsEnabled="False" Content="Saltar" />
            <Button x:Name="ResetBtn" Click="ResetBtn_Click" IsEnabled="False" Content="Reiniciar" />
        </StackPanel>

        <HyperlinkButton x:Name="CompactBtn" Click="CompactBtn_Click" HorizontalAlignment="Center"
                         AutomationProperties.Name="Activar modo isla">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE944;" FontSize="13" />
                <TextBlock Text="Modo isla (minimizar a la esquina)" />
            </StackPanel>
        </HyperlinkButton>

        <TextBlock x:Name="PresetInfo" Opacity="0.55" FontSize="12"
                   TextAlignment="Center" HorizontalAlignment="Center" />

        <Border x:Name="DndBadge" Visibility="Collapsed" HorizontalAlignment="Center"
                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                CornerRadius="12" Padding="12,4" Margin="0,4,0,0">
            <TextBlock Text="🔕 No molestar activo" FontSize="12"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
        </Border>
    </StackPanel>
</Page>
