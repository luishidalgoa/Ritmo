<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ritmo_App.SchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Horario semanal" FontSize="24" FontWeight="SemiBold" />
                <TextBlock x:Name="PhaseInfo" Opacity="0.7" FontSize="13" />
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0" VerticalAlignment="Center">
                    <Button x:Name="PrevWeekBtn" Click="PrevWeekBtn_Click" AutomationProperties.Name="Semana anterior" Padding="8,4">
                        <FontIcon Glyph="&#xE76B;" FontSize="12" />
                    </Button>
                    <TextBlock x:Name="WeekLabel" VerticalAlignment="Center" MinWidth="180" TextAlignment="Center"
                               FontSize="13" FontWeight="SemiBold" />
                    <Button x:Name="NextWeekBtn" Click="NextWeekBtn_Click" AutomationProperties.Name="Semana siguiente" Padding="8,4">
                        <FontIcon Glyph="&#xE76C;" FontSize="12" />
                    </Button>
                    <Button x:Name="ThisWeekBtn" Click="ThisWeekBtn_Click" Content="Esta semana" Padding="10,4" Margin="6,0,0,0" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="TaskBehaviorBtn" Click="TaskBehaviorBtn_Click"
                        AutomationProperties.Name="Comportamiento por tarea" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="14" />
                        <TextBlock Text="Comportamiento por tarea" />
                    </StackPanel>
                </Button>
                <Button x:Name="AddBtn" Click="AddBtn_Click"
                        AutomationProperties.Name="Añadir sesión"
                        Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="Añadir sesión" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ScrollHost" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto" SizeChanged="ScrollHost_SizeChanged"
                          AutomationProperties.AutomationId="ScheduleScroller">
                <!-- La rejilla se genera en el code-behind dentro de este Grid -->
                <Grid x:Name="GridRoot" AutomationProperties.AutomationId="GridRoot" />
            </ScrollViewer>

            <!-- Panel lateral de detalle: sesión o evento del calendario (#114) -->
            <Border x:Name="DetailPanel" Grid.Column="1" Width="320" Visibility="Collapsed"
                    Margin="16,0,0,0" CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailContent" Padding="16" Spacing="12" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
