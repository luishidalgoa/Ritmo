<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ritmo_App.WorkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" Spacing="20" MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock Text="Trabajo" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Seguimiento de horas y ganancias por proyecto o cliente."
                               Opacity="0.7" FontSize="13" />
                </StackPanel>
                <Button x:Name="AddProjectBtn" Content="Nuevo proyecto" HorizontalAlignment="Right"
                        VerticalAlignment="Top" Click="AddProjectBtn_Click"
                        Style="{ThemeResource AccentButtonStyle}" />
            </Grid>

            <!-- Resumen global de todos los proyectos (#84 V3) -->
            <Border x:Name="GlobalCard" CornerRadius="10" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel x:Name="GlobalHost" Spacing="6" />
            </Border>

            <!-- Estado vacío -->
            <TextBlock x:Name="EmptyText" Visibility="Collapsed" Opacity="0.6" FontSize="14" TextWrapping="Wrap"
                       Text="Aún no tienes proyectos. Crea uno con «Nuevo proyecto» para empezar a registrar horas y ver tus ganancias." />

            <!-- Tarjetas de proyecto (una por proyecto, con sus gráficos) -->
            <StackPanel x:Name="ProjectsHost" Spacing="16" />
        </StackPanel>
    </ScrollViewer>
</Page>
