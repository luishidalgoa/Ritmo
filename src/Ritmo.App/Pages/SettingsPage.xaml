<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ritmo_App.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ritmo_App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="680" HorizontalAlignment="Left">
            <TextBlock Text="Ajustes" FontSize="28" FontWeight="SemiBold" />

            <!-- Pomodoro -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pomodoro" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <ContentControl x:Name="PomodoroHelp" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <NumberBox x:Name="FocusBox" Grid.Row="0" Grid.Column="0" Header="Concentración (min)"
                                   Minimum="1" Maximum="180" SmallChange="5" SpinButtonPlacementMode="Inline" />
                        <NumberBox x:Name="ShortBox" Grid.Row="0" Grid.Column="1" Header="Descanso corto (min)"
                                   Minimum="0" Maximum="60" SmallChange="1" SpinButtonPlacementMode="Inline" />
                        <NumberBox x:Name="LongBox" Grid.Row="1" Grid.Column="0" Header="Descanso largo (min)"
                                   Minimum="0" Maximum="120" SmallChange="5" SpinButtonPlacementMode="Inline" />
                        <NumberBox x:Name="CyclesBox" Grid.Row="1" Grid.Column="1" Header="Focos por descanso largo"
                                   Minimum="1" Maximum="12" SmallChange="1" SpinButtonPlacementMode="Inline" />
                    </Grid>
                    <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                               Text="Estos valores son el ritmo «Por defecto de la app». Crea ritmos con nombre para reutilizarlos al configurar cada entorno." />

                    <!-- Ritmos propios (#96) -->
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Mis ritmos" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ContentControl x:Name="RhythmsHelp" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="AddRhythmBtn" Click="AddRhythmBtn_Click" HorizontalAlignment="Right"
                                AutomationProperties.Name="Nuevo ritmo">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Nuevo ritmo" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <StackPanel x:Name="RhythmsList" Spacing="6" />
                    <TextBlock x:Name="RhythmsEmpty" Opacity="0.6" FontSize="12" Visibility="Collapsed"
                               Text="Aún no has creado ritmos propios. Usa «Nuevo ritmo» para añadir uno." />
                </StackPanel>
            </Border>

            <!-- Rango horario -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Horario" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Rango de horas que se muestra en la cuadrícula." Opacity="0.7" FontSize="13" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TimePicker x:Name="DayStartPicker" Header="Desde" ClockIdentifier="24HourClock" MinuteIncrement="30" />
                        <TimePicker x:Name="DayEndPicker" Header="Hasta" ClockIdentifier="24HourClock" MinuteIncrement="30" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Fases del plan (#46) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Fases del plan" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="AddPhaseBtn" Click="AddPhaseBtn_Click" HorizontalAlignment="Right"
                                AutomationProperties.Name="Nueva fase">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Nueva fase" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Cada fase tiene su propio horario y un rango de fechas (p. ej. «Primera vuelta», «Repaso»). El Horario muestra la fase vigente según la fecha; puedes ver otras desde el selector del Horario." />
                    <StackPanel x:Name="PhasesList" Spacing="8" />
                </StackPanel>
            </Border>

            <!-- Entornos de concentración (#53) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Entornos de concentración" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddEnvBtn" Click="AddEnvBtn_Click" HorizontalAlignment="Right"
                                AutomationProperties.Name="Añadir entorno">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Añadir entorno" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Qué ocurre al concentrarte: música, apps a cerrar, No molestar… El marcado como predeterminado (★) se usa cuando un bloque no tiene un entorno propio asignado." />
                    <StackPanel x:Name="EnvList" Spacing="8" />
                    <TextBlock x:Name="EnvEmpty" Text="Aún no hay entornos. Añade uno para personalizar tu concentración."
                               Opacity="0.6" FontSize="13" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Entorno por tipo de bloque (#70) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Entorno por tipo de bloque" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Elige qué entorno usar al concentrarte en cada tipo de bloque del horario. «Por defecto» usa el entorno predeterminado (★)." />
                    <StackPanel x:Name="KindEnvList" Spacing="8" />
                    <TextBlock x:Name="KindEnvHint" Opacity="0.6" FontSize="13" TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Text="Crea al menos un entorno arriba para poder asignarlo a un tipo de bloque." />
                </StackPanel>
            </Border>

            <!-- Apps vinculadas (#107) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Apps vinculadas" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Conecta servicios externos una vez aquí; luego los usas en tus entornos." />

                    <TextBlock Text="MÚSICA" FontSize="11" FontWeight="SemiBold" Opacity="0.55" />
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE93C;" FontSize="15" VerticalAlignment="Center" />
                                <TextBlock Text="Navidrome" VerticalAlignment="Center" />
                                <TextBlock x:Name="NavHeaderStatus" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Spacing="12" Padding="4,8,4,4">
                            <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                                       Text="Conecta tu servidor de Navidrome. En cada entorno solo eliges una playlist. La contraseña se guarda en el almacén seguro de Windows, nunca en la copia de seguridad." />
                            <TextBox x:Name="NavServerBox" Header="URL del servidor" PlaceholderText="https://music.midominio.com" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NavUserBox" Grid.Column="0" Header="Usuario" />
                                <PasswordBox x:Name="NavPassBox" Grid.Column="1" Header="Contraseña" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="NavConnectBtn" Click="NavConnectBtn_Click" Content="Conectar" Style="{StaticResource AccentButtonStyle}" />
                                <Button x:Name="NavDisconnectBtn" Click="NavDisconnectBtn_Click" Content="Desconectar" />
                                <TextBlock x:Name="NavStatus" VerticalAlignment="Center" Opacity="0.85" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <TextBlock Text="CALENDARIO" FontSize="11" FontWeight="SemiBold" Opacity="0.55" Margin="0,4,0,0" />
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap">
                        <Run Text="Suscríbete por enlace ICS (" />
                        <Hyperlink NavigateUri="https://calendar.google.com">Google</Hyperlink>
                        <Run Text=": «dirección secreta en formato iCal»; " />
                        <Hyperlink NavigateUri="https://outlook.live.com/calendar/">Outlook</Hyperlink>
                        <Run Text=": «publicar calendario»; " />
                        <Hyperlink NavigateUri="https://www.icloud.com/es-es/calendar">iCloud</Hyperlink>
                        <Run Text=": «calendario público»). Solo lectura: tus eventos aparecen en «Hoy»." />
                    </TextBlock>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CalNameBox" Grid.Column="0" PlaceholderText="Nombre" Width="130"
                                 AutomationProperties.Name="Nombre del calendario" />
                        <TextBox x:Name="CalUrlBox" Grid.Column="1" PlaceholderText="https://…/basic.ics"
                                 AutomationProperties.Name="Enlace ICS" />
                        <Button x:Name="CalAddBtn" Grid.Column="2" Click="CalAddBtn_Click" Content="Añadir"
                                AutomationProperties.Name="Agregar calendario" />
                    </Grid>
                    <StackPanel x:Name="CalFeedsList" Spacing="4" />
                </StackPanel>
            </Border>

            <!-- Apariencia -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Apariencia" FontSize="18" FontWeight="SemiBold" />
                    <ComboBox x:Name="ThemeBox" Header="Tema" Width="240">
                        <ComboBoxItem Content="Según el sistema" Tag="Default" />
                        <ComboBoxItem Content="Claro" Tag="Light" />
                        <ComboBoxItem Content="Oscuro" Tag="Dark" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Notas y enlaces rápidos (#55) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Notas" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button x:Name="AddNoteBtn" Click="AddNoteBtn_Click" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="13" />
                                <TextBlock Text="Añadir nota" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Notas fijadas (admiten Markdown). Aparecen en la pantalla «Hoy». Los enlaces ahora viven en cada entorno de trabajo." />
                    <StackPanel x:Name="NotesList" Spacing="8" />
                </StackPanel>
            </Border>

            <!-- Copia de seguridad (#56) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Copia de seguridad" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Exporta toda tu configuración (horario, fases, entornos, notas, ajustes) a un archivo, o impórtala para restaurarla. Importar reemplaza la configuración actual." />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ExportBtn" Click="ExportBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEDE1;" FontSize="14" />
                                <TextBlock Text="Exportar configuración" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportBtn" Click="ImportBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                                <TextBlock Text="Importar configuración" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="BackupStatus" VerticalAlignment="Center" Opacity="0.8" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Segundo plano y arranque (#24/#20) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Segundo plano y arranque" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="13" TextWrapping="Wrap"
                               Text="Al cerrar la ventana, Ritmo sigue en segundo plano para que los avisos del horario suenen igualmente. Vuelve a abrirlo desde el menú Inicio o usa «Salir» para cerrarlo del todo." />
                    <ToggleSwitch x:Name="AutostartSwitch" Header="Arrancar Ritmo al iniciar sesión en Windows"
                                  OffContent="No" OnContent="Sí" Toggled="AutostartSwitch_Toggled" />
                    <TextBlock x:Name="AutostartHint" Opacity="0.6" FontSize="12" TextWrapping="Wrap" />
                    <Button x:Name="ExitBtn" Click="ExitBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7E8;" FontSize="14" />
                            <TextBlock Text="Salir de Ritmo (detiene los avisos)" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Guardar -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="SaveBtn" Click="SaveBtn_Click" Style="{StaticResource AccentButtonStyle}" Content="Guardar cambios" />
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Opacity="0.8" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
